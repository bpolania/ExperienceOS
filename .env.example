# Qwen Cloud credentials for the optional live demo path.
#
# Copy this file to .env (which is gitignored — never commit it).
# The dashboard and the Qwen examples load .env automatically when
# python-dotenv is installed (included in the demo extra):
#
#     pip install -e ".[demo]"
#     cp .env.example .env
#
# Only the API key is required; the rest have safe defaults.

QWEN_API_KEY=
# DASHSCOPE_API_KEY=            # alternative to QWEN_API_KEY
# QWEN_MODEL=qwen-plus
# QWEN_BASE_URL=https://dashscope-intl.aliyuncs.com/compatible-mode/v1
